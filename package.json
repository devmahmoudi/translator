{
  "name": "@devmahmoudi/translator",
  "description": "Data translation tool js SDK",
  "version": "0.1.3",
  "type": "module",
  "main": "dist/index.js",
  "module": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
